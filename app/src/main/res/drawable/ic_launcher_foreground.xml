<?xml version="1.0" encoding="utf-8"?>
<!--
    Source: Tabler Icons — letter-k (tabler.io/icons/icon/letter-k)
    Original: 24×24 viewBox, stroke-based, scaled 4.5× to 108×108.

    Path anatomy in 24×24 space:
      M7,4 v16          → vertical bar
      m0,-8 h2 l8,-8    → junction + upper arm to (17,4)
      m-8,8 l8,8        → junction + lower arm to (17,20)

    Scaled to 108:  multiply coords × 4.5
      Vertical bar:  (31.5, 18) → (31.5, 90)
      Upper arm:     junction (40.5, 54) → (76.5, 18)
      Lower arm:     junction (40.5, 54) → (76.5, 90)

    Tips land at ~42dp from centre and are clipped by the adaptive icon
    circle — with round linecaps this gives a natural, polished finish.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M31.5,18 v72 m0,-36 h9 l36,-36 m-36,36 l36,36"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="@android:color/transparent" />

</vector>
